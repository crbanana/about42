---
interface Props {
  title: string;
  date: Date;
  tags: string[];
}
const { title, date, tags } = Astro.props;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — HYPERISE</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen">
    <main class="max-w-3xl mx-auto px-6 py-12">
      <nav class="mb-8">
        <a href="/" class="text-indigo-400 hover:text-indigo-300 transition font-medium">← На главную</a>
      </nav>
      <header class="mb-12 pb-8 border-b border-zinc-800">
        <h1 class="text-4xl font-extrabold tracking-tight mb-4 text-white">{title}</h1>
        <div class="flex flex-wrap gap-3 text-sm text-zinc-400 items-center">
          <time class="font-medium">{date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
          {tags.length > 0 && (
            <span class="text-zinc-600">•</span>
          )}
          {tags.map((tag) => (
            <span class="bg-zinc-800/80 px-3 py-1 rounded-full text-zinc-300 text-xs font-medium">#{tag}</span>
          ))}
        </div>
      </header>
      <article class="prose prose-invert prose-zinc max-w-none">
        <slot />
      </article>
      <footer class="mt-16 pt-8 border-t border-zinc-800 text-center">
        <a href="/" class="text-indigo-400 hover:text-indigo-300 transition font-medium">← Все статьи</a>
      </footer>
    </main>
  </body>
</html>
