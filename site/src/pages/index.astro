---
import { getCollection } from 'astro:content';
const articles = await getCollection('articles', ({ data }) => !data.draft);
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>HYPERISE — О Пятерке</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen">
    <main class="max-w-3xl mx-auto px-6 py-12">
      <header class="mb-12">
        <h1 class="text-4xl font-extrabold tracking-tight mb-2">HYPERISE</h1>
        <p class="text-zinc-400 text-lg">Истории, новости, лонгриды и заметки о стримере Пятерка</p>
      </header>

      <section>
        <h2 class="text-xl font-semibold mb-6 text-zinc-300">Последние статьи</h2>
        {articles.length === 0 && (
          <p class="text-zinc-500">Пока статей нет. Скоро появятся!</p>
        )}
        <ul class="space-y-6">
          {articles.map((article) => (
            <li class="border-b border-zinc-800 pb-6">
              <a href={`/articles/${article.slug}`} class="group block">
                <h3 class="text-xl font-bold text-zinc-100 group-hover:text-indigo-400 transition mb-1">
                  {article.data.title}
                </h3>
                <time class="text-sm text-zinc-500">
                  {article.data.date.toLocaleDateString('ru-RU')}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
